Bootstrap: docker
From: ubuntu:22.04

%labels
 	Author Cameron Brown
	Description Portable container for bcftools, PLINK2, IBIS, and RaPID
%post
	set -e
	export DEBIAN_FRONTEND=noninteractive

	apt-get update && apt-get install -y \
        	bcftools \
        	build-essential \
        	ca-certificates \
        	curl \
        	git \
        	perl \
        	python3 \
        	python3-pip \
        	unzip \
        	wget \
        	zlib1g-dev \
    	&& apt-get clean \
    	&& rm -rf /var/lib/apt/lists/*
# ----------------------------
    # Install PLINK2
    # ----------------------------
    cd /opt
    curl -L -o plink2.zip https://s3.amazonaws.com/plink2-assets/alpha6/plink2_linux_avx2_20260228.zip
    unzip plink2.zip
    mv plink2 /usr/local/bin/plink2
    chmod +x /usr/local/bin/plink2
    rm -f plink2.zip

    # ----------------------------
    # Install IBIS
    # ----------------------------
    cd /opt
    git clone --recurse-submodules https://github.com/williamslab/ibis.git
    cd /opt/ibis
    make
    cp ibis /usr/local/bin/ibis
    cp add-map-plink.pl /usr/local/bin/add-map-plink.pl
    chmod +x /usr/local/bin/ibis /usr/local/bin/add-map-plink.pl

    # ----------------------------
    # Install RaPID
    # ----------------------------
    cd /opt
    git clone https://github.com/ZhiGroup/RaPID.git
    chmod +x /opt/RaPID/RaPID_v.1.7 || true
    ln -s /opt/RaPID/RaPID_v.1.7 /usr/local/bin/RaPID_v1.7
    chmod +x /opt/RaPID/filter_mapping_file.py /opt/RaPID/interpolate_loci.py || true
%environment
	export PATH=/usr/local/bin:$PATH
	export LC_ALL=C
%runscript
	exec "$@"

